{
  "hooks": {
    "post_write_code": [
      {
        "command": "echo \"[HOOK] File modified: ${FILE_PATH}\" >> .codex/logs/cascade-activity.log",
        "show_output": false,
        "working_directory": "."
      }
    ],
    "pre_run_command": [
      {
        "command": "echo \"[HOOK] Command: ${COMMAND}\" >> .codex/logs/cascade-activity.log",
        "show_output": false,
        "working_directory": "."
      }
    ]
  }
}
